{
  "name": "bootstrap-icons-cypress",
  "version": "1.0.0",
  "description": "Cypress tests for the bootstrap-icons Jahia module",
  "scripts": {
    "e2e:ci": "cypress run",
    "e2e:debug": "cypress open",
    "report:merge": "mochawesome-merge results/reports/cypress*.json > results/reports/report.json && rm results/reports/cypress*.json",
    "report:html": "marge --inline results/reports/report.json --reportDir results/reports/"
  },
  "devDependencies": {
    "@apollo/client": "^3.14.0",
    "@jahia/cypress": "^7.0.0",
    "cross-fetch": "3.1.6",
    "cypress": "^14.0.0",
    "cypress-multi-reporters": "^1.6.3",
    "cypress-terminal-report": "^5.3.7",
    "cypress-wait-until": "^3.0.1",
    "graphql": "^15.10.1",
    "graphql-tag": "^2.12.6",
    "mocha": "^10.0.0",
    "mocha-junit-reporter": "^2.2.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.2.0",
    "mochawesome-report-generator": "^6.3.2",
    "typescript": "^4.4.4"
  },
  "packageManager": "yarn@1.22.22"
}
